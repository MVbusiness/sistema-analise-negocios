// Processar envio do formulário
document.getElementById('businessForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    try {
        showMessage('Coletando dados...', 'success');
        
        // Coletar dados
        const formData = collectFormData();
        
        // Validar dados obrigatórios
        if (!validateForm(formData)) {
            showMessage('Por favor, preencha todos os campos obrigatórios!', 'error');
            return;
        }
        
        // Mostrar loading
        document.getElementById('loading').style.display = 'block';
        
        // Gerar resumo com IA (Gratuito com Hugging Face)
        showMessage('Gerando análise com IA...');
        formData.aiSummary = await generateAISummary(formData);
        
        // Calcular KPIs
        formData.kpis = calculateKPIs(formData);
        
        // Salvar dados
        formData.id = Date.now();
        formData.date = new Date().toLocaleDateString('pt-BR');
        allBusinessData.push(formData);
        localStorage.setItem('businessData', JSON.stringify(allBusinessData));
        
        // Gerar PDF
        await generatePDF(formData);
        
        // Salvar no Firebase se disponível
        // await saveToDB(formData);
        
        document.getElementById('loading').style.display = 'none';
        showMessage('✅ Relatório gerado com sucesso!', 'success');
        
        // Limpar formulário
        document.getElementById('businessForm').reset();
        document.getElementById('message').style.display = 'none';
        
    } catch (error) {
        console.error('Erro:', error);
        document.getElementById('loading').style.display = 'none';
        showMessage(`Erro ao gerar relatório: ${error.message}`, 'error');
    }
});

// Coletar dados do formulário
function collectFormData() {
    const nichos = Array.from(document.querySelectorAll('input[name="nicho"]:checked'))
        .map(el => el.value);
    
    const outroNicho = nichos.includes('Outros') ? document.getElementById('outroNicho').value : '';
    
    const data = {
        // Dados do Cliente
        clientName: document.getElementById('clientName').value,
        especialista: document.getElementById('especialista').value,
        phone: document.getElementById('phone').value,
        email: document.getElementById('email').value,
        revenue: parseFloat(document.getElementById('revenue').value),
        goal: parseFloat(document.getElementById('goal').value),
        
        // Nicho
        nichos: nichos,
        outroNicho: outroNicho,
        
        // Objetivos
        objetivo6m: document.getElementById('objetivo6m').value,
        dificuldade: document.getElementById('dificuldade').value,
        
        // Análises
        site: collectChannelData('site'),
        instagram: collectChannelData('insta'),
        tiktok: collectChannelData('tiktok'),
        
        // Orientações
        orientacoes: document.getElementById('orientacoes').value
    };
    
    return data;
}

// Coletar dados de um canal específico
function collectChannelData(platform) {
    const ratings = {};
    
    // Coletar ratings padrão
    const radios = document.querySelectorAll(`input[name^="${platform}_"]`);
    radios.forEach(radio => {
        if (radio.checked) {
            ratings[radio.name.replace(`${platform}_`, '')] = parseInt(radio.value);
        }
    });
    
    // Coletar campos personalizados
    const customFields = document.getElementById(`customFields-${platform}`);
    const customData = {};
    
    if (customFields) {
        customFields.querySelectorAll('.custom-field').forEach(field => {
            const fieldName = field.querySelector('.field-name')?.value || 
                            field.parentElement.textContent.match(/Nome do campo[^:]*:\s*([^\n]*)/)?.[1];
            const selectedRating = field.querySelector('input[type="radio"]:checked');
            
            if (fieldName && selectedRating) {
                customData[fieldName] = parseInt(selectedRating.value);
            }
        });
    }
    
    return { ...ratings, ...customData };
}

// Validar formulário
function validateForm(data) {
    return data.clientName && 
           data.especialista && 
           data.phone && 
           data.email && 
           data.revenue && 
           data.goal && 
           data.nichos.length > 0 &&
           data.objetivo6m &&
           data.dificuldade &&
           data.orientacoes;
}

// Gerar resumo com IA (Hugging Face - 100% Gratuito)
async function generateAISummary(formData) {
