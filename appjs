Dificuldade principal: ${formData.dificuldade}

Avaliações:
- Site: ${JSON.stringify(formData.site)}
- Instagram: ${JSON.stringify(formData.instagram)}
- TikTok: ${JSON.stringify(formData.tiktok)}

Forneça uma análise concisa e objetiva com recomendações práticas.
        `;

        // Usando Hugging Face Inference API (GRATUITO)
        const response = await fetch('https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-chat-hf', {
            method: 'POST',
            headers: {
                Authorization: 'Bearer hf_kJzXxXxxXxXxXxXxXxXxXxXxXxXxXxXx', // SUBSTITUIR por seu token gratuito
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                inputs: prompt,
                parameters: {
                    max_new_tokens: 200,
                    temperature: 0.7,
                }
            })
        });

        if (!response.ok) {
            // Se falhar, retornar resumo genérico
            return `
Diagnóstico do Negócio de ${formData.clientName}:

O negócio no segmento de ${formData.nichos.join(', ')} apresenta desafios relacionados a: ${formData.dificuldade}

Recomendações principais:
1. Melhorar os canais com avaliação mais baixa
2. Focar na diversificação de tráfego
3. Implementar estratégias de retenção de clientes
4. Otimizar descrições de produtos e proposta de valor

Potencial de crescimento: ELEVADO com as ações corretas.
            `;
        }

        const result = await response.json();
        return result[0]?.generated_text || generateFallbackSummary(formData);
        
    } catch (error) {
        console.error('Erro na IA:', error);
        return generateFallbackSummary(formData);
    }
}

