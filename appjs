// Função para mostrar mensagens
function showMessage(text, type = 'success') {
    const messageDiv = document.getElementById('message');
    messageDiv.className = `message ${type}`;
    messageDiv.textContent = text;
    messageDiv.style.display = 'block';
    
    if (type === 'success') {
        setTimeout(() => {
            messageDiv.style.display = 'none';
        }, 5000);
    }
}

// Adicionar campo personalizado
function addCustomField(platform) {
    const container = document.getElementById(`customFields-${platform}`);
    const fieldId = `custom-${platform}-${Date.now()}`;
    
    const html = `
        <div class="custom-field">
            <input type="text" placeholder="Nome do campo" class="field-name" value="">
            <div class="rating-scale" style="flex: 1; margin-bottom: 0;">
                <input type="radio" name="${fieldId}" value="0"> 0
                <input type="radio" name="${fieldId}" value="1"> 1
                <input type="radio" name="${fieldId}" value="2"> 2
                <input type="radio" name="${fieldId}" value="3"> 3
                <input type="radio" name="${fieldId}" value="4"> 4
                <input type="radio" name="${fieldId}" value="5"> 5
                <div class="rating-value">-</div>
            </div>
            <button type="button" class="remove-btn" onclick="this.parentElement.remove()">Remover</button>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', html);
    
    // Adicionar listener para atualizar rating
    const radioButtons = container.lastElementChild.querySelectorAll(`input[name="${fieldId}"]`);
    radioButtons.forEach(radio => {
        radio.addEventListener('change', (e) => {
            const ratingValue = e.target.parentElement.querySelector('.rating-value');
            ratingValue.textContent = e.target.value;
        });
    });
}

