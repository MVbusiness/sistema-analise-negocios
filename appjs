        item.nichos.join('; ')
    ]);
    
    let csv = headers.join(',') + '\n';
    rows.forEach(row => {
        csv += row.map(cell => `"${cell}"`).join(',') + '\n';
    });
    
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.setAttribute('href', url);
    link.setAttribute('download', `Leads_${new Date().getTime()}.csv`);
    link.click();
}

// Mostrar leads salvos
function showSavedLeads() {
    if (allBusinessData.length === 0) {
        alert('Nenhum registro salvo!');
        return;
    }
    
    let html = '<h3>Leads Salvos</h3><table border="1" cellpadding="10"><tr><th>Data</th><th>Cliente</th><th>Especialista</th><th>Nicho</th><th>Meta</th></tr>';
    
    allBusinessData.forEach(item => {
        html += `<tr>
            <td>${item.date}</td>
            <td>${item.clientName}</td>
            <td>${item.especialista}</td>
            <td>${item.nichos.join(', ')}</td>
            <td>R$ ${item.goal.toLocaleString('pt-BR')}</td>
        </tr>`;
    });
    
    html += '</table>';
    
    const modal = window.open('', 'Leads', 'width=800,height=600');
    modal.document.write(html);
    modal.document.close();
}

