// Calcular nota média
function calculateAverageRating(data) {
    const allRatings = [
        ...Object.values(data.site || {}),
        ...Object.values(data.instagram || {}),
        ...Object.values(data.tiktok || {})
    ].filter(v => typeof v === 'number');
    
    if (allRatings.length === 0) return 0;
    return allRatings.reduce((a, b) => a + b) / allRatings.length;
}

// Calcular KPIs
function calculateKPIs(data) {
    const kpis = [];
    const avgRating = calculateAverageRating(data);
    const gapPercentual = ((data.goal - data.revenue) / data.revenue) * 100;
    
    // KPI 1: Crescimento necessário
    kpis.push({
        title: 'CRESCIMENTO NECESSÁRIO',
        value: `${gapPercentual.toFixed(1)}%`,
        urgency: gapPercentual > 100 ? 'CRÍTICO' : gapPercentual > 50 ? 'ALTO' : 'MÉDIO',
        description: `Precisa crescer de R$ ${data.revenue.toLocaleString('pt-BR')} para R$ ${data.goal.toLocaleString('pt-BR')}`
    });
    
    // KPI 2: Saúde Digital
    kpis.push({
        title: 'SAÚDE DIGITAL',
        value: `${(avgRating * 20).toFixed(0)}%`,
        urgency: avgRating >= 4 ? 'BAIXO' : avgRating >= 3 ? 'MÉDIO' : 'ALTO',
        description: `Nota média: ${avgRating.toFixed(1)}/5 - ${avgRating >= 4 ? 'Excelente presença online' : avgRating >= 3 ? 'Presença consolidada' : 'Necessário melhorias urgentes'}`
    });
    
    // KPI 3: Canal mais fraco
    const channels = {
        'Site': calculateChannelAverage(data.site),
        'Instagram': calculateChannelAverage(data.instagram),
        'TikTok': calculateChannelAverage(data.tiktok)
    };
    
    const weakestChannel = Object.entries(channels).sort((a, b) => a[1] - b[1])[0];
    kpis.push({
        title: 'CANAL COM MAIOR POTENCIAL',
        value: weakestChannel[0],
        urgency: weakestChannel[1] < 2 ? 'CRÍTICO' : weakestChannel[1] < 3 ? 'ALTO' : 'MÉDIO',
        description: `${weakestChannel[0]} com nota ${weakestChannel[1].toFixed(1)}/5 - Melhorar este canal pode gerar impacto imediato`
    });
    
    // KPI 4: Readiness
    const readiness = data.site && data.instagram && data.tiktok ? 
        (calculateChannelAverage(data.site) + calculateChannelAverage(data.instagram) + calculateChannelAverage(data.tiktok)) / 3 : 0;
    
    kpis.push({
        title: 'READINESS PARA ESCALAR',
        value: readiness >= 4 ? 'PRONTO' : readiness >= 3 ? 'PARCIAL' : 'NÃO PRONTO',
        urgency: readiness < 3 ? 'CRÍTICO' : readiness < 4 ? 'MÉDIO' : 'BAIXO',
        description: `Negócio ${readiness >= 4 ? 'está pronto para investimentos em marketing' : readiness >= 3 ? 'precisa de ajustes antes de escalar' : 'precisa de otimizações estruturais'}`
    });
    
    return kpis;
}

// Calcular média de um canal
function calculateChannelAverage(channelData) {
    if (!channelData || Object.keys(channelData).length === 0) return 0;
    const values = Object.values(channelData).filter(v => typeof v === 'number');
    if (values.length === 0) return 0;
    return values.reduce((a, b) => a + b) / values.length;
}

