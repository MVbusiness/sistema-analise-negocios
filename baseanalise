// Gerar HTML das avaliações
function generateRatingsHTML(ratings) {
    if (!ratings || Object.keys(ratings).length === 0) {
        return '<p style="font-size: 10px; color: #999;">Nenhuma avaliação realizada</p>';
    }
    
    return Object.entries(ratings).map(([key, value]) => {
        const barWidth = (value / 5) * 100;
        return `
            <div style="margin: 10px 0; font-size: 10px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span>${key}</span>
                    <span style="font-weight: bold; color: #667eea;">${value}/5</span>
                </div>
                <div style="background: #e0e0e0; height: 8px; border-radius: 4px; overflow: hidden;">
                    <div style="background: linear-gradient(to right, #667eea, #764ba2); height: 100%; width: ${barWidth}%; border-radius: 4px;"></div>
                </div>
            </div>
        `;
    }).join('');
}

// Criar gráfico radar
function createRadarChart(data, callback) {
    const labels = [];
    const dataPoints = [];
    
    // Site
    if (data.site) {
        Object.entries(data.site).forEach(([key, value]) => {
            labels.push(`Site: ${key}`);
            dataPoints.push(value);
        });
    }
    
    // Instagram
    if (data.instagram) {
        Object.entries(data.instagram).forEach(([key, value]) => {
            labels.push(`IG: ${key}`);
            dataPoints.push(value);
        });
    }
    
    // TikTok
    if (data.tiktok) {
        Object.entries(data.tiktok).forEach(([key, value]) => {
            labels.push(`TK: ${key}`);
            dataPoints.push(value);
        });
    }
    
    const canvas = document.getElementById('radarChart');
    if (!canvas) {
        callback();
        return;
    }
    
    const ctx = canvas.getContext('2d');
    new Chart(ctx, {
        type: 'radar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Avaliação do Negócio',
                data: dataPoints,
                borderColor: '#667eea',
                backgroundColor: 'rgba(102, 126, 234, 0.1)',
                borderWidth: 2,
                fill: true,
                pointBackgroundColor: '#667eea',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
                r: {
                    beginAtZero: true,
                    max: 5,
                    ticks: {
                        stepSize: 1
                    }
                }
            },
            plugins: {
                legend: {
                    display: true,
                    position: 'bottom',
                    labels: {
                        font: { size: 10 }
                    }
                }
            }
        },
        plugins: [{
            afterDatasetsDraw: function() {
                callback();
            }
        }]
    });
}

