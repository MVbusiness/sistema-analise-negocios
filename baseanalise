// Exportar leads para CSV
function exportLeadsToCSV() {
    if (allBusinessData.length === 0) {
        alert('Nenhum registro para exportar!');
        return;
    }
    
    const headers = ['Data', 'Cliente', 'Especialista', 'Email', 'Telefone', 'Faturamento', 'Meta', 'Nicho'];
    const rows = allBusinessData.map(item => [
        item.date,
        item.clientName,
        item.especialista,
        item.email,
        item.phone,
        `R$ ${item.revenue.toLocaleString('pt-BR')}`,
        `R$ ${item.goal.toLocaleString('pt-BR')}`,
        item.nichos.join('; ')
    ]);
    
    let csv = headers.join(',') + '\n';
    rows.forEach(row => {
        csv += row.map(cell => `"${cell}"`).join(',') + '\n';
    });
    
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.setAttribute('href', url);
    link.setAttribute('download', `Leads_${new Date().getTime()}.csv`);
    link.click();
}

