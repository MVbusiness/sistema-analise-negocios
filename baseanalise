    try {
        showMessage('Coletando dados...', 'success');
        
        // Coletar dados
        const formData = collectFormData();
        
        // Validar dados obrigatórios
        if (!validateForm(formData)) {
            showMessage('Por favor, preencha todos os campos obrigatórios!', 'error');
            return;
        }
        
        // Mostrar loading
        document.getElementById('loading').style.display = 'block';
        
        // Gerar resumo com IA (Gratuito com Hugging Face)
        showMessage('Gerando análise com IA...');
        formData.aiSummary = await generateAISummary(formData);
        
        // Calcular KPIs
        formData.kpis = calculateKPIs(formData);
        
        // Salvar dados
        formData.id = Date.now();
        formData.date = new Date().toLocaleDateString('pt-BR');
        allBusinessData.push(formData);
        localStorage.setItem('businessData', JSON.stringify(allBusinessData));
        
        // Gerar PDF
        await generatePDF(formData);
        
        // Salvar no Firebase se disponível
        // await saveToDB(formData);
        
        document.getElementById('loading').style.display = 'none';
        showMessage('✅ Relatório gerado com sucesso!', 'success');
        
        // Limpar formulário
        document.getElementById('businessForm').reset();
        document.getElementById('message').style.display = 'none';
        
    } catch (error) {
        console.error('Erro:', error);
        document.getElementById('loading').style.display = 'none';
        showMessage(`Erro ao gerar relatório: ${error.message}`, 'error');
    }
});

// Coletar dados do formulário
function collectFormData() {
    const nichos = Array.from(document.querySelectorAll('input[name="nicho"]:checked'))
        .map(el => el.value);
    
    const outroNicho = nichos.includes('Outros') ? document.getElementById('outroNicho').value : '';
    
    const data = {
        // Dados do Cliente
        clientName: document.getElementById('clientName').value,
        especialista: document.getElementById('especialista').value,
        phone: document.getElementById('phone').value,
        email: document.getElementById('email').value,
        revenue: parseFloat(document.getElementById('revenue').value),
        goal: parseFloat(document.getElementById('goal').value),
        
        // Nicho
        nichos: nichos,
        outroNicho: outroNicho,
        
        // Objetivos
        objetivo6m: document.getElementById('objetivo6m').value,
        dificuldade: document.getElementById('dificuldade').value,
        
        // Análises
        site: collectChannelData('site'),
        instagram: collectChannelData('insta'),
        tiktok: collectChannelData('tiktok'),
        
        // Orientações
        orientacoes: document.getElementById('orientacoes').value
    };
    
    return data;
}

// Coletar dados de um canal específico
function collectChannelData(platform) {
    const ratings = {};
    
    // Coletar ratings padrão
    const radios = document.querySelectorAll(`input[name^="${platform}_"]`);
    radios.forEach(radio => {
        if (radio.checked) {
            ratings[radio.name.replace(`${platform}_`, '')] = parseInt(radio.value);
        }
    });
    
    // Coletar campos personalizados
    const customFields = document.getElementById(`customFields-${platform}`);
    const customData = {};
    
    if (customFields) {
        customFields.querySelectorAll('.custom-field').forEach(field => {
            const fieldName = field.querySelector('.field-name')?.value || 
                            field.parentElement.textContent.match(/Nome do campo[^:]*:\s*([^\n]*)/)?.[1];
            const selectedRating = field.querySelector('input[type="radio"]:checked');
            
            if (fieldName && selectedRating) {
                customData[fieldName] = parseInt(selectedRating.value);
            }
        });
    }
    
    return { ...ratings, ...customData };
}

// Validar formulário
function validateForm(data) {
    return data.clientName && 
           data.especialista && 
           data.phone && 
           data.email && 
           data.revenue && 
           data.goal && 
           data.nichos.length > 0 &&
           data.objetivo6m &&
           data.dificuldade &&
           data.orientacoes;
}

// Gerar resumo com IA (Hugging Face - 100% Gratuito)
async function generateAISummary(formData) {
    try {
        const prompt = `
Gere um breve diagnóstico executivo (máximo 200 palavras) para este negócio:

Cliente: ${formData.clientName}
Nicho: ${formData.nichos.join(', ')}
Faturamento atual: R$ ${formData.revenue.toLocaleString('pt-BR')}
Meta mensal: R$ ${formData.goal.toLocaleString('pt-BR')}

Objetivo (6 meses): ${formData.objetivo6m}
Dificuldade principal: ${formData.dificuldade}

Avaliações:
- Site: ${JSON.stringify(formData.site)}
- Instagram: ${JSON.stringify(formData.instagram)}
- TikTok: ${JSON.stringify(formData.tiktok)}

Forneça uma análise concisa e objetiva com recomendações práticas.
        `;

        // Usando Hugging Face Inference API (GRATUITO)
        const response = await fetch('https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-chat-hf', {
            method: 'POST',
            headers: {
                Authorization: 'Bearer hf_kJzXxXxxXxXxXxXxXxXxXxXxXxXxXxXx', // SUBSTITUIR por seu token gratuito
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                inputs: prompt,
                parameters: {
                    max_new_tokens: 200,
                    temperature: 0.7,
                }
            })
        });

        if (!response.ok) {
            // Se falhar, retornar resumo genérico
            return `
Diagnóstico do Negócio de ${formData.clientName}:

O negócio no segmento de ${formData.nichos.join(', ')} apresenta desafios relacionados a: ${formData.dificuldade}

Recomendações principais:
1. Melhorar os canais com avaliação mais baixa
2. Focar na diversificação de tráfego
3. Implementar estratégias de retenção de clientes
4. Otimizar descrições de produtos e proposta de valor

Potencial de crescimento: ELEVADO com as ações corretas.
            `;
        }

        const result = await response.json();
        return result[0]?.generated_text || generateFallbackSummary(formData);
        
    } catch (error) {
        console.error('Erro na IA:', error);
        return generateFallbackSummary(formData);
    }
}

// Resumo fallback quando IA falha
function generateFallbackSummary(formData) {
    const avgRating = calculateAverageRating(formData);
    const status = avgRating >= 4 ? 'EXCELENTE' : avgRating >= 3 ? 'BOM' : avgRating >= 2 ? 'REGULAR' : 'CRÍTICO';
    
    return `
DIAGNÓSTICO EXECUTIVO

Negócio: ${formData.clientName}
Nicho: ${formData.nichos.join(', ')}

STATUS GERAL: ${status} (Nota média: ${avgRating.toFixed(1)}/5)

Desafio Principal: ${formData.dificuldade}
Objetivo: ${formData.objetivo6m}

RECOMENDAÇÕES:
${formData.site && Object.values(formData.site).some(v => v < 2) ? '• Urgente: Melhorar presença no site\n' : ''}
${formData.instagram && Object.values(formData.instagram).some(v => v < 2) ? '• Urgente: Fortalecer estratégia no Instagram\n' : ''}
${formData.tiktok && Object.values(formData.tiktok).some(v => v < 2) ? '• Urgente: Otimizar presença no TikTok\n' : ''}

Potencial de crescimento: ELEVADO

Próximos passos conforme orientações do especialista.
    `.trim();
}

// Calcular nota média
function calculateAverageRating(data) {
    const allRatings = [
        ...Object.values(data.site || {}),
        ...Object.values(data.instagram || {}),
        ...Object.values(data.tiktok || {})
    ].filter(v => typeof v === 'number');
    
    if (allRatings.length === 0) return 0;
    return allRatings.reduce((a, b) => a + b) / allRatings.length;
}

// Calcular KPIs
function calculateKPIs(data) {
    const kpis = [];
    const avgRating = calculateAverageRating(data);
    const gapPercentual = ((data.goal - data.revenue) / data.revenue) * 100;
    
    // KPI 1: Crescimento necessário
    kpis.push({
        title: 'CRESCIMENTO NECESSÁRIO',
        value: `${gapPercentual.toFixed(1)}%`,
        urgency: gapPercentual > 100 ? 'CRÍTICO' : gapPercentual > 50 ? 'ALTO' : 'MÉDIO',
        description: `Precisa crescer de R$ ${data.revenue.toLocaleString('pt-BR')} para R$ ${data.goal.toLocaleString('pt-BR')}`
    });
    
    // KPI 2: Saúde Digital
    kpis.push({
        title: 'SAÚDE DIGITAL',
        value: `${(avgRating * 20).toFixed(0)}%`,
        urgency: avgRating >= 4 ? 'BAIXO' : avgRating >= 3 ? 'MÉDIO' : 'ALTO',
        description: `Nota média: ${avgRating.toFixed(1)}/5 - ${avgRating >= 4 ? 'Excelente presença online' : avgRating >= 3 ? 'Presença consolidada' : 'Necessário melhorias urgentes'}`
    });
    
    // KPI 3: Canal mais fraco
    const channels = {
        'Site': calculateChannelAverage(data.site),
        'Instagram': calculateChannelAverage(data.instagram),
        'TikTok': calculateChannelAverage(data.tiktok)
    };
    
    const weakestChannel = Object.entries(channels).sort((a, b) => a[1] - b[1])[0];
    kpis.push({
        title: 'CANAL COM MAIOR POTENCIAL',
        value: weakestChannel[0],
        urgency: weakestChannel[1] < 2 ? 'CRÍTICO' : weakestChannel[1] < 3 ? 'ALTO' : 'MÉDIO',
        description: `${weakestChannel[0]} com nota ${weakestChannel[1].toFixed(1)}/5 - Melhorar este canal pode gerar impacto imediato`
    });
    
    // KPI 4: Readiness
    const readiness = data.site && data.instagram && data.tiktok ? 
        (calculateChannelAverage(data.site) + calculateChannelAverage(data.instagram) + calculateChannelAverage(data.tiktok)) / 3 : 0;
    
    kpis.push({
        title: 'READINESS PARA ESCALAR',
        value: readiness >= 4 ? 'PRONTO' : readiness >= 3 ? 'PARCIAL' : 'NÃO PRONTO',
        urgency: readiness < 3 ? 'CRÍTICO' : readiness < 4 ? 'MÉDIO' : 'BAIXO',
        description: `Negócio ${readiness >= 4 ? 'está pronto para investimentos em marketing' : readiness >= 3 ? 'precisa de ajustes antes de escalar' : 'precisa de otimizações estruturais'}`
    });
    
    return kpis;
}

// Calcular média de um canal
function calculateChannelAverage(channelData) {
    if (!channelData || Object.keys(channelData).length === 0) return 0;
    const values = Object.values(channelData).filter(v => typeof v === 'number');
    if (values.length === 0) return 0;
    return values.reduce((a, b) => a + b) / values.length;
}

